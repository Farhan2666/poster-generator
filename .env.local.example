# === AI PROVIDER KEYS ===
# Gemini — untuk analyze-image dan scene (vision tasks)
GEMINI_API_KEY=

# DeepSeek — untuk hook, script, cta (text tasks, termurah)
DEEPSEEK_API_KEY=

# OpenAI — fallback jika provider lain error
OPENAI_API_KEY=

# === SUPABASE ===
# URL project + anon key untuk client
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key untuk admin operations (server-only, jangan pernah expose ke client)
SUPABASE_SERVICE_ROLE_KEY=
